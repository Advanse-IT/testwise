name               = "testwise-contact"
main               = "index.js"
compatibility_date = "2024-09-23"
compatibility_flags = ["nodejs_compat"]

[[kv_namespaces]]
binding = "CONTACT_KV"
id      = "PASTE_YOUR_KV_NAMESPACE_ID_HERE"

# Secrets — set via CLI:
# wrangler secret put RESEND_API_KEY  →  re_xxxxxxxxxxxx  (from resend.com/api-keys)
# wrangler secret put FROM_EMAIL      →  hello@advanseit.com.au
# wrangler secret put NOTIFY_TO       →  admin@advanseit.com.au
